# ===== Baza danych =====
# Do testów lokalnych: SQLite (domyślnie włączone). Plik: data/app.db
USE_SQLITE=1
SQLITE_PATH=data/app.db

# Opcjonalnie: wyłączenie bazy (np. tylko podgląd UI). Przy włączonym USE_SQLITE baza działa.
# SKIP_DB=1

# Po wdrożeniu na DigitalOcean: PostgreSQL (wyłącz SQLite, ustaw DATABASE_URL):
# USE_SQLITE=0
# DATABASE_URL=postgresql://user:password@host:port/dbname

# Przy współdzielonej bazie z inną aplikacją – osobny schemat (tabele w find_friends, bez konfliktów):
# DB_SCHEMA=find_friends

# Opcjonalnie (gdy nie używasz DATABASE_URL):
# DB_HOST=localhost
# DB_NAME=hobby
# DB_USER=postgres
# DB_PASSWORD=...
# DB_PORT=5432
